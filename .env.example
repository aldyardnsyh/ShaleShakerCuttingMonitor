# Copy to .env and adjust as needed.

# Your domain name (used by Caddy reverse proxy for HTTPS).
# Set this before first docker compose up on the VPS.
DOMAIN=contoh-domain.com

# Timezone used for server-side timestamps (IANA name).
APP_TIMEZONE=Asia/Jakarta

# ONNX Runtime CPU threads (match VPS vCPUs).
ORT_INTRA_OP_THREADS=2
ORT_INTER_OP_THREADS=1

# Inference defaults
DEFAULT_MODEL=mobilevit
DEFAULT_STRIDE=3
MIN_STONE_AREA=8

# Auto-cleanup: delete video files of completed sessions older than N days.
CLEANUP_RETENTION_DAYS=3
